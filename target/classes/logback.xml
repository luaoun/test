<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false">
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <!-- 格式化输出：%d表示日期，%thread表示线程名，%-5level：级别从左显示5个字符宽度%msg：日志消息，%n是换行符 -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %level [${SYSNAME},%X{X-B3-TraceId:-},%X{X-B3-SpanId:-},%X{msgTraceId},%X{X-Span-Export:-}] [%thread] %class.%method:%line - %msg%n" />

    <!--定义日志文件的名称-->
    <property name="appName" value="ifp-operation" />
    <!--定义自己的日志文件的存储地址-->
    <property name="LOG_HOME" value="logs" />

    <conversionRule conversionWord="myMsg" converterClass="com.pxsemic.lves.config.CustomMessageConverter" />
    <conversionRule conversionWord="ex" converterClass="com.pxsemic.lves.config.ExceptionProxyConverter" />

    <!--日志输出格式-->
    <property name="logPattern" value="%d %-5level PID=${PID:- } [%-20thread] %-40.40logger{40} [line = %-5line] [method = %-20.20method]: %msg%n"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--文件日志， 按照每天生成日志文件 -->
    <appender name="INFO_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 日志记录器的滚动策略，按日期，按大小记录 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 每天日志归档路径以及格式 -->
            <fileNamePattern>${LOG_HOME}/${appName}.%d{yyyy-MM-dd}.%i.info.log.gz</fileNamePattern>
            <totalSizeCap>20GB</totalSizeCap>
            <maxFileSize>200MB</maxFileSize>
            <!--日志文件保留天数-->
            <maxHistory>10</maxHistory>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>

        <encoder charset="UTF-8" class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <pattern>
                    <pattern>
                        {
                        <!--服务名称-->
                        "appName": "${appName}",
                        <!--打印时间-->
                        "time": "%date{yyyy-MM-dd HH:mm:ss}",
                        <!--日志级别-->
                        "level": "%level",
                        <!--全限定类名-->
                        "class": "%logger",
                        <!--类中的哪个方法-->
                        "method": "%method",
                        <!--类中的第几行-->
                        "line": "%line",
                        <!--日志打印的信息-->
                        "message": "%replace(%replace(%replace(%myMsg){'(\n)','#'}){'(\r)','#'}){'(\t)','#'}%replace(%replace(%replace(%ex){'(\n)','#'}){'(\r)','#'}){'(\t)','#'}%nopex"
                        }
                    </pattern>
                </pattern>
            </providers>
        </encoder>
        <!--
        <encoder>
            <pattern>${logPattern}</pattern>
        </encoder>
        -->
    </appender>

    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>

        <!-- 日志记录器的滚动策略，按日期，按大小记录 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 每天日志归档路径以及格式 -->
            <fileNamePattern>${LOG_HOME}/${appName}.%d{yyyy-MM-dd}.%i.error.log.gz</fileNamePattern>
            <totalSizeCap>20GB</totalSizeCap>
            <maxFileSize>200MB</maxFileSize>
            <!--日志文件保留天数-->
            <maxHistory>10</maxHistory>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>

        <encoder charset="UTF-8" class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <pattern>
                    <pattern>
                        {
                        <!--服务名称-->
                        "appName": "${appName}",
                        <!--打印时间-->
                        "time": "%date{yyyy-MM-dd HH:mm:ss}",
                        <!--日志级别-->
                        "level": "%level",
                        <!--全限定类名-->
                        "class": "%logger",
                        <!--类中的哪个方法-->
                        "method": "%method",
                        <!--类中的第几行-->
                        "line": "%line",
                        <!--日志打印的信息-->
                        "message": "%replace(%replace(%replace(%myMsg){'(\n)','#'}){'(\r)','#'}){'(\t)','#'}%replace(%replace(%replace(%ex){'(\n)','#'}){'(\r)','#'}){'(\t)','#'}%nopex"
                        }
                    </pattern>
                </pattern>
            </providers>
        </encoder>
    </appender>

    <!--mybatis log configure-->
    <logger name="com.apache.ibatis" level="TRACE"/>
    <logger name="java.sql.Connection" level="INFO"/>
    <logger name="java.sql.Statement" level="INFO"/>
    <logger name="java.sql.PreparedStatement" level="INFO"/>

    <!-- 只将 com.pxsemic 包下的日志输出到文件 -->
    <logger name="com.px" level="debug" additivity="false">
        <appender-ref ref="INFO_FILE" />
    </logger>
    <logger name="com.px" level="ERROR" additivity="false">
        <appender-ref ref="ERROR_FILE" />
    </logger>

    <!-- 其他日志输出到控制台 -->
    <root level="info">
        <appender-ref ref="STDOUT" />
    </root>

</configuration>
